<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ohgiraffers.spotifyminispringmybatis.comment.model.dao.CommentMapper">
    <resultMap id="CommentResultMap" type="com.ohgiraffers.spotifyminispringmybatis.comment.model.dto.CommentDTO">
        <id property="commentId" column="comment_id"/>
        <result property="content" column="content"/>
        <result property="userId" column="user_id"/>
        <result property="musicId" column="music_id"/>
    </resultMap>

    <select id="findCommentsByUserAndMusic" parameterType="_int" resultMap="CommentResultMap">
        SELECT
        comment_id
        , content
        , user_id
        , music_id
        FROM comments
        WHERE music_id = #{musicId}
        AND user_id = #{userId}
    </select>

    <insert id="registComment" parameterType="com.ohgiraffers.spotifyminispringmybatis.comment.model.dto.CommentDTO"
        useGeneratedKeys = "true" keyProperty="commentId" >
        INSERT INTO comments
        ( content, user_id, music_id)
        values
        ( #{content}, #{userId}, #{musicId} )
    </insert>
</mapper>
